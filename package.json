{
  "name": "scenes",
  "version": "0.0.0",
  "description": "Agent skill for interactive educational Three.js scenes, plus local CLI and viewer to manage and explore them.",
  "type": "module",
  "bin": {
    "scenes": "./bin/scenes.js"
  },
  "files": [
    "bin",
    "dist",
    "viewer/dist",
    "scenes-skill",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run build:viewer",
    "build:viewer": "vite build --config viewer/vite.config.ts",
    "build:cli": "tsc",
    "test": "npm run build && node --test --import ./test/register-three-hook.js test/params.test.js test/scene-validate.test.js test/cli.test.js test/show.test.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "three.js",
    "education",
    "agent-skill",
    "cli",
    "scenes"
  ],
  "author": "Igo Akulov",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igoakulov/scenes.git"
  },
  "bugs": {
    "url": "https://github.com/igoakulov/scenes/issues"
  },
  "homepage": "https://github.com/igoakulov/scenes#readme",
  "dependencies": {
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.3.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.21",
    "lucide-react": "^1.26.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.14.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  }
}
